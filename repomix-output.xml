<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id              String          @id @default(uuid())
  name            String          @unique
  code            String          @unique
  password        String
  email           String          @unique
  phone           String
  schoolName      String
  schoolAddress   String
  documentUrl     String?
  sourceInfo      String?  //update
  competitionType CompetitionType
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  currentStageId  String?
  twibbonUrl      String?
  attempts        ExamAttempt[]
  members         Member[]
  registration    Registration?
  submissions     Submission[]
  currentStage    Stage?          @relation("TeamCurrentStage", fields: [currentStageId], references: [id])
  
  mentor          Mentor? 

  @@map("team")
}

model Mentor {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String

  teamId    String   @unique
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id        String     @id @default(uuid())
  name      String
  role      MemberRole
  email     String     @unique
  phone     String     

  // khusus LKTI
  major     String?    // prodi
  faculty   String?    // fakultas

  teamId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Admin {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attempts      ExamAttempt[]
  registrations Registration[]
  submissions   Submission[]

  @@map("admin")
}

model Competition {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  batches       Batch[]
  registrations Registration[]
  stages        Stage[]
}

model Batch {
  id            String         @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  price         Decimal
  module_bacth  String
  competitionId String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  competition   Competition    @relation(fields: [competitionId], references: [id])
  registrations Registration[]

  @@unique([name, competitionId])
}

model Stage {
  id            String       @id @default(uuid())
  name          StageType
  competitionId String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  order         Int
  exams         Exam[]
  competition   Competition  @relation(fields: [competitionId], references: [id])
  submissions   Submission[]
  teamsCurrent  Team[]       @relation("TeamCurrentStage")

  @@unique([name, competitionId])
  @@unique([competitionId, order])
}

model Registration {
  id            String        @id @default(uuid())
  competitionId String
  batchId       String
  paymentProof  String?
  status        PaymentStatus @default(PENDING)
  approvedBy    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  teamId        String        @unique
  admin         Admin?        @relation(fields: [approvedBy], references: [id])
  batch         Batch         @relation(fields: [batchId], references: [id])
  competition   Competition   @relation(fields: [competitionId], references: [id])
  team          Team          @relation(fields: [teamId], references: [id])
}

model Submission {
  id             String           @id @default(uuid())
  teamId         String
  stageId        String
  title          String?
  fileUrl        String?
  status         SubmissionStatus @default(PENDING)
  reviewedBy     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  feedback       String?
  score          Int?
  orsinalitasUrl String?
  turnitinUrl    String?
  abstractUrl    String?
  admin          Admin?           @relation(fields: [reviewedBy], references: [id])
  stage          Stage            @relation(fields: [stageId], references: [id])
  team           Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, stageId])
}

model File {
  url    String
  fileId String @unique

  @@index([url])
}

model Exam {
  id        String         @id @default(uuid())
  title     String
  type      ExamType
  startDate DateTime
  endDate   DateTime
  stageId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  duration  Int            @default(90)
  stage     Stage          @relation(fields: [stageId], references: [id])
  attempts  ExamAttempt[]
  questions ExamQuestion[]

  @@unique([title, stageId], name: "title_stageId")
}

model ExamQuestion {
  id            String       @id @default(uuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  optionE       String
  order         Int                 @default(0)
  correctAnswer String
  correctScore    Int
  wrongScore      Int
  emptyScore      Int
  examId        String
  createdAt     DateTime     @default(now())
  answers       ExamAnswer[]
  exam          Exam         @relation(fields: [examId], references: [id])

  difficulty      QuestionDifficulty  @default(EASY)
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model ExamAttempt {
  id              String         @id @default(uuid())
  teamId          String
  examId          String
  totalScore      Int            @default(0)
  startTime       DateTime       @default(now())
  endTime         DateTime?
  finished        Boolean        @default(false)
  reviewedBy      String?
  createdAt       DateTime       @default(now())
  deviceId        String?
  ipAddress       String?
  userAgent       String?
  cheatCount      Int            @default(0)
  flagged         Boolean        @default(false)
  suspiciousScore Int            @default(0)
  answers         ExamAnswer[]
  exam            Exam           @relation(fields: [examId], references: [id])
  admin           Admin?         @relation(fields: [reviewedBy], references: [id])
  team            Team           @relation(fields: [teamId], references: [id])
  events          ExamEventLog[]

  @@unique([teamId, examId])
}

model ExamEventLog {
  id        String        @id @default(uuid())
  attemptId String
  type      ExamEventType
  metadata  Json?
  createdAt DateTime      @default(now())
  attempt   ExamAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model ExamAnswer {
  id         String       @id @default(uuid())
  attemptId  String
  questionId String
  answer     String
  isCorrect  Boolean
  answeredAt DateTime     @default(now())
  attempt    ExamAttempt  @relation(fields: [attemptId], references: [id])
  question   ExamQuestion @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
}

enum CompetitionType {
  OLIMPIADE
  LKTI
  INFOGRAFIS
}

enum MemberRole {
  KETUA
  ANGGOTA
}

enum ExamEventType {
  TAB_SWITCH
  WINDOW_BLUR
  WINDOW_FOCUS
  COPY
  PASTE
  FULLSCREEN_EXIT
  MULTIPLE_LOGIN
  NETWORK_CHANGE
  DEVTOOLS_OPEN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StageType {
  PENYISIHAN
  SEMIFINAL
  FINAL
}

enum ExamType {
  TRYOUT
  OLYMPIAD
}
