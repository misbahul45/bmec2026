        .fromTo(
          descRef.current,
          { y: 30, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.6 },
          '-=0.5'
        )
        .fromTo(
          ctaRef.current,
          { y: 20, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.5 },
          '-=0.3'
        )
        .fromTo(
          maskotLeftRef.current,
          { y: 60, opacity: 0, scale: 0.8, rotate: -10 },
          { y: 0, opacity: 1, scale: 1, rotate: 0, duration: 0.8, ease: 'back.out(1.7)' },
          '-=0.6'
        )
        .fromTo(
          maskotRightRef.current,
          { y: -60, opacity: 0, scale: 0.8, rotate: 10 },
