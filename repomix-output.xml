        <div className="absolute inset-0 flex items-center justify-center">
          <div className="w-full max-w-xs sm:max-w-lg lg:max-w-2xl px-4 sm:px-6 text-center flex flex-col items-center gap-3 sm:gap-5 lg:gap-6">
