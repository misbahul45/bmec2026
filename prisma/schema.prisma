generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CompetitionType {
  OLIMPIADE
  LKTI
  INFOGRAFIS
}

enum MemberRole {
  KETUA
  ANGGOTA
}

model Team {
  id        String   @id @default(uuid())

  name      String   @unique
  code      String   @unique
  password  String
  email     String   @unique
  
  phone     String
  schoolName    String
  schoolAddress String
  documentUrl String?

  members Member[]

  registration Registration?

  submissions Submission[]
  competitionType CompetitionType
  abstract AbstractSubmission?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team")
}

model AbstractSubmission {
  id String @id @default(uuid())

  teamId String @unique
  fileUrl String

  status SubmissionStatus @default(PENDING)

  reviewedBy String?
  admin Admin? @relation(fields: [reviewedBy], references: [id])

  team Team @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id String @id @default(uuid())

  name String
  studentId String @unique
  role MemberRole 

  teamId String
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())

  name      String
  email     String   @unique
  password  String

  registrations Registration[]
  submissions Submission[]
  abstracts AbstractSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin")
}

model Competition {
  id        String   @id @default(uuid())

  name      String  @unique

  batches   Batch[]
  stages    Stage[]

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Batch {
  id        String   @id @default(uuid())

  name      String
  startDate DateTime
  endDate   DateTime
  price     Decimal

  module_bacth String

  competitionId String
  competition Competition @relation(fields: [competitionId], references: [id])

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, competitionId]) 
}

model Stage {
  id String @id @default(uuid())

  name StageType

  competitionId String
  competition Competition @relation(fields: [competitionId], references: [id])

  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Registration {
  id String @id @default(uuid())

  teamId String @unique
  competitionId String
  batchId String

  paymentProof String?

  status PaymentStatus @default(PENDING)

  team Team @relation(fields: [teamId], references: [id])
  competition Competition @relation(fields: [competitionId], references: [id])
  batch Batch @relation(fields: [batchId], references: [id])

  approvedBy String?
  admin Admin? @relation(fields: [approvedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id String @id @default(uuid())

  teamId String
  stageId String

  title String?
  fileUrl String?

  status SubmissionStatus @default(PENDING)

  team Team @relation(fields: [teamId], references: [id])
  stage Stage @relation(fields: [stageId], references: [id])

  reviewedBy String?
  admin Admin? @relation(fields: [reviewedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model File {
  url     String
  fileId String @unique

  @@index([url])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StageType {
  PENYISIHAN
  SEMIFINAL
  FINAL
}