generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CompetitionType {
  OLIMPIADE
  LKTI
  INFOGRAFIS
}

enum MemberRole {
  KETUA
  ANGGOTA
}

model Team {
  id        String   @id @default(uuid())

  name      String   @unique
  code      String   @unique
  password  String
  email     String   @unique
  
  phone     String
  schoolName    String
  schoolAddress String
  documentUrl String?

  members Member[]

  registration Registration?

  submissions Submission[]
  competitionType CompetitionType
  abstract AbstractSubmission?
  attempts ExamAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team")
}

model AbstractSubmission {
  id String @id @default(uuid())

  teamId String @unique
  fileUrl String

  status SubmissionStatus @default(PENDING)

  reviewedBy String?
  admin Admin? @relation(fields: [reviewedBy], references: [id])

  team Team @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id String @id @default(uuid())

  name String
  studentId String @unique
  role MemberRole 

  teamId String
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())

  name      String
  email     String   @unique
  password  String

  registrations Registration[]
  submissions Submission[]
  abstracts AbstractSubmission[]
  attempts ExamAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin")
}

model Competition {
  id        String   @id @default(uuid())

  name      String  @unique

  batches   Batch[]
  stages    Stage[]

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Batch {
  id        String   @id @default(uuid())

  name      String
  startDate DateTime
  endDate   DateTime
  price     Decimal

  module_bacth String

  competitionId String
  competition Competition @relation(fields: [competitionId], references: [id])

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, competitionId]) 
}

model Stage {
  id String @id @default(uuid())

  name StageType

  competitionId String
  competition Competition @relation(fields: [competitionId], references: [id])

  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exams Exam[]
  @@unique([name, competitionId])
}

model Registration {
  id String @id @default(uuid())

  teamId String @unique
  competitionId String
  batchId String

  paymentProof String?

  status PaymentStatus @default(PENDING)

  team Team @relation(fields: [teamId], references: [id])
  competition Competition @relation(fields: [competitionId], references: [id])
  batch Batch @relation(fields: [batchId], references: [id])

  approvedBy String?
  admin Admin? @relation(fields: [approvedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id String @id @default(uuid())

  teamId String
  stageId String

  title String?
  fileUrl String?

  score Int?
  feedback String?

  status SubmissionStatus @default(PENDING)

  team Team @relation(fields: [teamId], references: [id])
  stage Stage @relation(fields: [stageId], references: [id])

  reviewedBy String?
  admin Admin? @relation(fields: [reviewedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, stageId])
}

model File {
  url     String
  fileId String @unique

  @@index([url])
}


model Exam {
  id String @id @default(uuid())

  title String
  type ExamType

  startDate DateTime
  endDate DateTime

  stageId String
  stage Stage @relation(fields: [stageId], references: [id])

  questions ExamQuestion[]
  attempts ExamAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExamQuestion {
  id String @id @default(uuid())

  question String

  optionA String
  optionB String
  optionC String
  optionD String
  optionE String

  correctAnswer String
  score Int @default(5)

  examId String
  exam Exam @relation(fields: [examId], references: [id])

  answers ExamAnswer[]

  createdAt DateTime @default(now())
}

model ExamAttempt {
  id String @id @default(uuid())

  teamId String
  examId String

  totalScore Int @default(0)

  startTime DateTime @default(now())
  endTime DateTime?

  finished Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id])
  exam Exam @relation(fields: [examId], references: [id])

  ipAddress String?
  userAgent String?
  deviceId String?

  cheatCount Int @default(0)          // jumlah event
  suspiciousScore Int @default(0)     // tingkat kecurangan
  flagged Boolean @default(false)     // status

  answers ExamAnswer[]
  events ExamEventLog[]

  reviewedBy String?
  admin Admin? @relation(fields: [reviewedBy], references: [id])

  createdAt DateTime @default(now())

  @@unique([teamId, examId])
}

model ExamEventLog {
  id String @id @default(uuid())

  attemptId String
  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  type ExamEventType
  metadata Json?

  createdAt DateTime @default(now())

  @@index([attemptId])
}

enum ExamEventType {
  TAB_SWITCH
  WINDOW_BLUR
  WINDOW_FOCUS
  COPY
  PASTE
  FULLSCREEN_EXIT
  MULTIPLE_LOGIN
  NETWORK_CHANGE
  DEVTOOLS_OPEN
}

model ExamAnswer {
  id String @id @default(uuid())

  attemptId String
  questionId String

  answer String
  isCorrect Boolean

  attempt ExamAttempt @relation(fields: [attemptId], references: [id])
  question ExamQuestion @relation(fields: [questionId], references: [id])

  answeredAt DateTime @default(now())

  @@unique([attemptId, questionId])
}
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StageType {
  PENYISIHAN
  SEMIFINAL
  FINAL
}

enum ExamType {
  TRYOUT
  OLYMPIAD
}